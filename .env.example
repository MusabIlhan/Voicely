# Twilio Configuration
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview

# Server Configuration
BRIDGE_SERVER_PORT=8080
BRIDGE_SERVER_HOST=localhost
NEXT_PUBLIC_BRIDGE_SERVER_URL=http://localhost:8080

# For production/ngrok — the public URL where Twilio can reach the bridge server
PUBLIC_SERVER_URL=https://your-ngrok-url.ngrok.io

# Google Calendar (Service Account — optional fallback)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=your_private_key
GOOGLE_CALENDAR_ID=primary

# Google OAuth (for user-based Calendar connect)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Recall.ai (Meeting Bot)
RECALL_API_KEY=your_recall_api_key
RECALL_API_BASE_URL=https://eu-central-1.recall.ai/api/v1

# External Main Agent
MAIN_AGENT_BASE_URL=http://localhost:8090
MAIN_AGENT_ASSIST_URL=http://localhost:8090/assist
MAIN_AGENT_SESSION_END_URL=http://localhost:8090/session-end
MAIN_AGENT_BEARER_TOKEN=your_main_agent_bearer_token

# MCP Server — URL the MCP server uses to reach the bridge server
BRIDGE_SERVER_URL=http://localhost:8080

# Remote MCP (Claude Mobile / Web) — optional API key to protect the endpoint
# If not set, the endpoint is open (fine for development)
MCP_API_KEY=

# Public app URL (used to display the MCP endpoint URL to users)
NEXT_PUBLIC_APP_URL=http://localhost:3001
